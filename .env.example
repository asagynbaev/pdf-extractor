# PDF: absolute or relative path; if unset, first *.pdf in current directory is used
# PDF_PATH=Yassako Technical Handover Report.pdf

# PaddleOCR 3.x — PP-OCRv5 (see PaddleOCR docs for supported lang codes: en, ru, ch, ...)
PADDLE_OCR_LANG=en
# Optional document preprocessors (slower; enable for skewed photos)
# PADDLE_USE_DOC_ORIENTATION=true
# PADDLE_USE_DOC_UNWARPING=true
# PADDLE_USE_TEXTLINE_ORIENTATION=true
# Skip slow model-host connectivity check on locked-down networks
# PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True

# If a page has fewer non-whitespace characters than this, render and run OCR (scanned/sloppy PDFs)
MIN_NATIVE_TEXT_CHARS=50

# Render DPI for OCR rasterization (higher = slower, sharper)
OCR_RENDER_DPI=200

# Optional: limit pages for a quick run (empty = all pages)
# MAX_PAGES=5
